<script>
	// ── Module-level IDs so the persistent astro:before-swap listener
	//    can cancel pending work regardless of when it fires ─────────────
	let particleRafId = 0;
	let scrambleRafId = 0;
	let scrambleTimerId: ReturnType<typeof setTimeout> | undefined;
	let glitchTimerId: ReturnType<typeof setTimeout> | undefined;

	interface Particle { x: number; y: number; speed: number; size: 1 | 2; color: string; opacity: number; phase: number; }

	// ── Pixel particle canvas ────────────────────────────────────────────
	function initParticles() {
		const canvas = document.getElementById('particle-canvas') as HTMLCanvasElement | null;
		if (!canvas) return;
		const ctx = canvas.getContext('2d');
		if (!ctx) return;

		function mkParticle(scattered = false): Particle {
			const s = getComputedStyle(document.documentElement);
			const colors = [
				`rgb(${s.getPropertyValue('--color-gold')})`,
				`rgb(${s.getPropertyValue('--color-green')})`,
				`rgb(${s.getPropertyValue('--color-orange')})`,
				`rgb(${s.getPropertyValue('--color-lime')})`,
			];
			return {
				x: Math.random() * canvas!.width,
				y: scattered ? Math.random() * canvas!.height : canvas!.height + Math.random() * 80,
				speed: 0.15 + Math.random() * 0.3,
				size: Math.random() < 0.65 ? 1 : 2,
				color: colors[Math.floor(Math.random() * colors.length)],
				opacity: 0.1 + Math.random() * 0.22,
				phase: Math.random() * Math.PI * 2,
			};
		}

		const COUNT = 30;
		const particles: Particle[] = [];
		let tick = 0;

		function resize() {
			canvas!.width = window.innerWidth;
			canvas!.height = window.innerHeight;
		}

		function setup() {
			resize();
			particles.length = 0;
			for (let i = 0; i < COUNT; i++) particles.push(mkParticle(true));
		}

		function draw() {
			tick++;
			ctx!.clearRect(0, 0, canvas!.width, canvas!.height);
			for (const p of particles) {
				p.y -= p.speed;
				p.x += Math.sin(tick * 0.01 + p.phase) * 0.12;
				const alpha = p.opacity * (0.5 + 0.5 * Math.sin(tick * 0.018 + p.phase));
				ctx!.globalAlpha = alpha;
				ctx!.fillStyle = p.color;
				ctx!.fillRect(Math.round(p.x), Math.round(p.y), p.size, p.size);
				if (p.y < -p.size) Object.assign(p, mkParticle(false));
			}
			ctx!.globalAlpha = 1;
			particleRafId = requestAnimationFrame(draw);
		}

		setup();
		draw();
		window.addEventListener('resize', setup, { passive: true });
	}

	// ── Text scramble decode on whoami line ─────────────────────────────
	function initScramble() {
		const el = document.getElementById('scramble-target');
		if (!el) return;
		const FINAL = '> backend engineer, snowboarder, builder';
		const CHARSET = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789@#$%&*!?';
		const DURATION_PER_CHAR = 40;
		const LEAD_CHARS = 4;

		function scramble(startTime: number, now: number) {
			const elapsed = now - startTime;
			const resolved = Math.min(Math.floor(elapsed / DURATION_PER_CHAR), FINAL.length);
			let output = '';
			for (let i = 0; i < FINAL.length; i++) {
				if (FINAL[i] === ' ') { output += ' '; continue; }
				if (i < resolved) {
					output += FINAL[i];
				} else if (i < resolved + LEAD_CHARS) {
					output += CHARSET[Math.floor(Math.random() * CHARSET.length)];
				} else {
					output += CHARSET[Math.floor(Math.random() * CHARSET.length)];
				}
			}
			el!.textContent = output;
			if (resolved < FINAL.length) {
				scrambleRafId = requestAnimationFrame(t => scramble(startTime, t));
			} else {
				el!.textContent = FINAL;
			}
		}

		scrambleTimerId = setTimeout(() => {
			el!.textContent = '';
			scrambleRafId = requestAnimationFrame(t => scramble(t, t));
		}, 800);
	}

	// ── ASCII banner glitch effect ───────────────────────────────────────
	function initGlitch() {
		const art = document.getElementById('ascii-art');
		if (!art) return;

		function triggerGlitch() {
			art!.classList.add('glitching');
			setTimeout(() => art!.classList.remove('glitching'), 220);
		}

		function scheduleGlitch() {
			const delay = 6000 + Math.random() * 3000;
			glitchTimerId = setTimeout(() => { triggerGlitch(); scheduleGlitch(); }, delay);
		}
		scheduleGlitch();

		art.addEventListener('mouseenter', triggerGlitch);
		art.addEventListener('click', () => {
			art!.classList.remove('clicked');
			// Force reflow so re-clicking restarts the animation
			void (art as HTMLElement).offsetWidth;
			art!.classList.add('clicked');
			art!.addEventListener('animationend', () => art!.classList.remove('clicked'), { once: true });
		});
	}

	// ── Easter egg: snowboarder on 7 rapid clicks ───────────────────────
	function initEasterEgg() {
		const banner = document.getElementById('ascii-banner');
		if (!banner) return;
		let clicks: number[] = [];
		banner.addEventListener('click', () => {
			const now = Date.now();
			clicks.push(now);
			clicks = clicks.filter(t => now - t < 5000);
			if (clicks.length >= 7) {
				clicks = [];
				const overlay = document.createElement('div');
				overlay.style.cssText = 'position:fixed;top:0;left:0;width:100vw;height:100vh;z-index:50;pointer-events:none;overflow:hidden;';
				document.body.appendChild(overlay);
				const boarder = document.createElement('div');
				boarder.innerHTML = `<svg width="24" height="24" viewBox="0 0 16 16" style="image-rendering:pixelated" fill="rgb(var(--color-green))">
					<rect x="7" y="1" width="3" height="1"/>
					<rect x="7" y="2" width="3" height="2"/>
					<rect x="7" y="2" width="3" height="1" fill="rgb(var(--color-orange))"/>
					<rect x="7" y="4" width="3" height="2" fill="rgb(var(--color-orange))"/>
					<rect x="5" y="4" width="2" height="1"/>
					<rect x="10" y="5" width="2" height="1"/>
					<rect x="6" y="6" width="2" height="2"/>
					<rect x="9" y="6" width="2" height="2"/>
					<rect x="4" y="8" width="9" height="2" rx="1" fill="rgb(var(--color-green))"/>
					<rect x="2" y="9" width="1" height="1" fill="rgb(var(--color-foreground))" opacity="0.5"/>
					<rect x="13" y="9" width="1" height="1" fill="rgb(var(--color-foreground))" opacity="0.5"/>
				</svg>`;
				boarder.style.cssText = 'position:absolute;z-index:10;pointer-events:none;';
				overlay.appendChild(boarder);
				const w = window.innerWidth;
				const h = window.innerHeight;
				const dur = 6000;
				const start = performance.now();
				const midX = w / 2;
				const sway = w * 0.4;
				const turns = 4;
				function getPos(t: number) {
					const x = midX + Math.sin(t * Math.PI * turns) * sway;
					const y = -24 + t * (h + 48);
					return { x, y };
				}
				const trailSvg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
				trailSvg.setAttribute('width', String(w));
				trailSvg.setAttribute('height', String(h));
				trailSvg.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;overflow:visible;';
				const trailPath = document.createElementNS('http://www.w3.org/2000/svg', 'path');
				trailPath.setAttribute('fill', 'none');
				trailPath.setAttribute('stroke', 'rgb(var(--color-foreground))');
				trailPath.setAttribute('stroke-opacity', '0.3');
				trailPath.setAttribute('stroke-width', '2');
				trailPath.setAttribute('stroke-linecap', 'round');
				trailPath.setAttribute('stroke-linejoin', 'round');
				trailSvg.appendChild(trailPath);
				overlay.appendChild(trailSvg);
				let pathData = '';
				function frame(time: number) {
					const p = Math.min((time - start) / dur, 1);
					const ease = p < 0.5 ? 2 * p * p : 1 - Math.pow(-2 * p + 2, 2) / 2;
					const { x, y } = getPos(ease);
					boarder.style.left = x + 'px';
					boarder.style.top = y + 'px';
					if (!pathData) {
						pathData = `M${x + 12} ${y + 20}`;
					} else {
						pathData += ` L${x + 12} ${y + 20}`;
					}
					trailPath.setAttribute('d', pathData);
					if (p < 1) {
						requestAnimationFrame(frame);
					} else {
						boarder.remove();
						trailSvg.style.transition = 'opacity 2s ease';
						requestAnimationFrame(() => { trailSvg.style.opacity = '0'; });
						setTimeout(() => { overlay.remove(); }, 2100);
					}
				}
				requestAnimationFrame(frame);
			}
		});
	}

	// ── Lifecycle: cleanup before swap, re-init after swap ───────────────
	function cleanupPage() {
		cancelAnimationFrame(particleRafId);
		cancelAnimationFrame(scrambleRafId);
		clearTimeout(scrambleTimerId);
		clearTimeout(glitchTimerId);
	}

	function initPage() {
		initParticles();
		initScramble();
		initGlitch();
		initEasterEgg();
	}

	// These listeners are registered once at module-eval time and persist
	// across all ViewTransitions navigations.
	document.addEventListener('astro:before-swap', cleanupPage);
	document.addEventListener('astro:after-swap', () => {
		if (document.getElementById('particle-canvas')) initPage();
	});

	initPage();
</script>
</BaseLayout>
